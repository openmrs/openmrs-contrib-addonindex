{
  "name": "openmrs-contrib-addonindex-ui",
  "description": "UI for the OpenMRS Add-On Index",
  "private": true,
  "scripts": {
    "build:watch": "parcel watch --dist-dir ../../../target/classes/static --cache-dir ../../../target/parcel-cache index.html",
    "build:dev": "NODE_ENV=development parcel build --dist-dir ../../../target/classes/static --cache-dir ../../../target/parcel-cache --no-optimize index.html",
    "build:prod": "parcel build --dist-dir ../../../target/classes/static --cache-dir ../../../target/parcel-cache index.html",
    "lint": "eslint --ext js,jsx,ts,tsx",
    "prettier": "prettier app/**/* --write",
    "test": "vitest run --passWithNoTests"
  },
  "engines": {
    "node": ">=10.23.2"
  },
  "keywords": [
    "OpenMRS"
  ],
  "author": "OpenMRS, Inc",
  "license": "MPL-2.0",
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "ignoreAssets": [
    ".ico"
  ],
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.1.1",
    "@fortawesome/free-regular-svg-icons": "^6.1.1",
    "@fortawesome/free-solid-svg-icons": "^6.1.1",
    "@fortawesome/react-fontawesome": "^0.1.18",
    "@tanstack/react-query": "^5.64.0",
    "bootstrap": "^4.6.1",
    "dayjs": "^1.11.19",
    "react": "^18.3.1",
    "react-bootstrap": "^1.6.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.1.1",
    "react-ga": "^3.3.1",
    "react-router": "^6.28.0",
    "react-router-dom": "^6.28.0",
    "react-select": "^5.10.2"
  },
  "devDependencies": {
    "@parcel/config-default": "^2.16.4",
    "@parcel/transformer-sass": "^2.16.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^5.25.0",
    "@typescript-eslint/parser": "^5.25.0",
    "browserslist-config-openmrs": "^1.0.1",
    "eslint": "^8.15.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react-hooks": "^4.5.0",
    "jsdom": "^28.1.0",
    "parcel": "^2.16.4",
    "parcel-resolver-ignore": "^2.1.1",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "sass": "^1.97.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "parcelIgnore": [
    "/favicon.ico",
    "https://id.openmrs.org/.*"
  ]
}
